{
  "name": "customerEQ",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "generate": "pnpm generate:baml",
    "generate:baml": "pnpm --filter @customerEQ/ai generate",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "pnpm --filter @customerEQ/web test:e2e",
    "test:e2e:demo": "pnpm --filter @customerEQ/demo-storefront test:e2e",
    "demo": "pnpm --filter @customerEQ/demo-storefront dev",
    "test:smoke": "turbo run test:smoke",
    "test:baml": "pnpm --filter @customerEQ/ai test:baml",
    "test:all": "turbo run test test:integration",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:studio": "pnpm --filter @customerEQ/database studio",
    "db:push": "pnpm --filter @customerEQ/database exec prisma db push",
    "db:migrate": "pnpm --filter @customerEQ/database exec prisma migrate deploy",
    "db:migrate:new": "pnpm --filter @customerEQ/database exec prisma migrate dev",
    "db:generate": "pnpm --filter @customerEQ/database exec prisma generate",
    "db:reset": "pnpm --filter @customerEQ/database exec prisma migrate reset",
    "healthz": "curl -s http://localhost:4000/healthz | python -m json.tool",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "onboard-org": "node scripts/onboard-org.mjs",
    "setup:dev-brand": "tsx --env-file=.env scripts/setup-dev-brand.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "run-scenario": "tsx scripts/run-scenario.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "tsx": "^4.9.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^10.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0"
  },
  "pnpm": {
    "overrides": {
      "next": "^15.5.18",
      "ioredis": "5.10.1",
      "@clerk/clerk-react": "^5.61.6",
      "fast-uri": ">=3.1.2"
    }
  }
}
