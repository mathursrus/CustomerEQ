// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProgramType {
  POINTS
  TIERED
  CASHBACK
  HYBRID
}

enum HaltBehavior {
  PAUSE_PROGRAM
  PAUSE_RULES
}

enum RewardType {
  DISCOUNT
  FREE_ITEM
  EXPERIENCE
  VOUCHER
}

enum ProgramStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum RuleStatus {
  ACTIVE
  INACTIVE
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  ERASED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum RedemptionStatus {
  PENDING
  FULFILLED
  CANCELLED
}

enum SurveyType {
  NPS
  CSAT
  CES
  CUSTOM
}

enum SurveyStatus {
  DRAFT
  ACTIVE
  PAUSED
  STOPPED // renamed from CLOSED per #241 / R25
}

enum ConversationStatus {
  ACTIVE
  WAITING_ON_CUSTOMER
  ESCALATED
  RESOLVED
  CLOSED
}

enum MessageRole {
  CUSTOMER
  AI
  AGENT
}

enum KBArticleCategory {
  FAQ
  POLICY
  TROUBLESHOOTING
  PRODUCT_GUIDE
  PROCESS
  OTHER
}

enum KBArticleStatus {
  DRAFT
  PUBLISHED
}

enum ExternalSourceType {
  GOOGLE_BUSINESS_PROFILE
  LINKEDIN_ORG
  REDDIT
  X
  GENERIC_WEBHOOK
  GENERIC_API
  APPLICATION
}

enum OrgSizeCategory {
  SIZE_1_10
  SIZE_11_50
  SIZE_51_300
  SIZE_301_5000
  SIZE_5000_PLUS
  PREFER_NOT_TO_SAY
}

enum UseCasePath {
  api
  site
  apps
  skipped
}

enum OnboardingStep {
  account_created
  org_profile_completed
  path_chosen
  data_source_connected
  first_event_received
  first_survey_published
  program_created
  first_action_triggered
  activated
}

enum ExternalSyncMode {
  WEBHOOK
  POLL
  MANUAL
}

enum ExternalSignalStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum ExternalMatchStatus {
  UNMATCHED
  CANDIDATE
  MATCHED
  REJECTED
}

// ─── Issue #231: Survey response data model rework ────────────────────────────

enum MemberIdentifierKind {
  EMAIL
  PHONE
  CUSTOMER_ID
}

enum ConsentMode {
  EXPLICIT
  IMPLIED_ON_SUBMIT
}

enum MemberEnrolledVia {
  MANUAL_API       // integrator POST /v1/members/enroll
  BULK_IMPORT      // bulk migration import
  SURVEY_RESPONSE  // auto-enrolled via standalone survey link/email — responder self-identified on form
  EMBEDDED_FORM    // auto-enrolled via host-application embedded survey — host SDK supplied identity via URL param
  CLERK_OAUTH      // signup via Clerk webhook
}

enum ResponsePolicy {
  ONCE
  MULTIPLE
  LATEST_OVERWRITES
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model Brand {
  id                    String                 @id @default(cuid())
  clerkOrgId            String                 @unique // Clerk organization ID → brandId mapping
  name                  String
  // Step 1.5 org-profile fields (Issue #170)
  siteDomain            String?
  logoUrl               String?
  // Issue #231 — Survey response data model rework
  memberIdentifierKind  MemberIdentifierKind   @default(EMAIL)   // R4
  consentMode           ConsentMode            @default(EXPLICIT) // R16
  consentTextDefault    String?                                  // R16 — brand-wide disclosure / checkbox text
  privacyPolicyUrl      String?                                  // R16 — captured at brand onboarding
  termsUrl              String?                                  // R16 — captured at brand onboarding
  // FK to BrandTheme.id when set. Restored in #291 alongside the SurveyTheme→BrandTheme split.
  defaultThemeId        String?
  defaultTheme          BrandTheme?            @relation("BrandDefaultTheme", fields: [defaultThemeId], references: [id])
  // Issue #277 — Organization Settings: orgSize (renamed from sizeCategory), timezone, locale.
  orgSize               OrgSizeCategory?
  timezone              String                 @default("UTC")
  locale                String                 @default("en-US")
  programs              Program[]
  members               Member[]
  surveys               Survey[]
  brandThemes           BrandTheme[]           @relation("BrandThemes")
  questionTemplates     QuestionTemplate[]
  alertRules            AlertRule[]
  caseFollowUps         CaseFollowUp[]
  conversations         Conversation[]
  supportRules          SupportRule[]
  cxPlaybooks           CxPlaybook[]
  externalSignalSources ExternalSignalSource[]
  externalSignals       ExternalSignal[]
  apiKeys               ApiKey[]
  webhookEndpoints      WebhookEndpoint[]
  // Onboarding (Issue #170)
  onboardingState       OnboardingState?
  activationEvents      OnboardingActivationEvent[]
  createdAt             DateTime               @default(now())

  @@map("brands")
}

// Developer API key — admin-generated, stored as SHA-256 hash. The plaintext
// is only ever shown once (at creation time). Used via the X-Api-Key header
// for server-to-server integration by the brand's own product (e.g. Acme
// Coffee's backend calling /v1/events).
model ApiKey {
  id                     String                @id @default(cuid())
  brandId                String
  brand                  Brand                 @relation(fields: [brandId], references: [id])
  name                   String // human label: "Production", "Staging", "Acme backend"
  keyPrefix              String // first 8 chars of plaintext (for display — not a secret)
  keyHash                String                @unique // SHA-256 hex of plaintext
  createdBy              String // clerk user ID that created it
  createdAt              DateTime              @default(now())
  lastUsedAt             DateTime?
  revokedAt              DateTime? // soft revoke — null = active
  // Per-app API key linkage (Issue #170 OD-2; consumed by #173)
  externalSignalSourceId String?
  externalSignalSource   ExternalSignalSource? @relation(fields: [externalSignalSourceId], references: [id], onDelete: SetNull)

  @@index([brandId, revokedAt])
  @@index([externalSignalSourceId])
  @@map("api_keys")
}

model Program {
  id                    String           @id @default(cuid())
  brandId               String
  brand                 Brand            @relation(fields: [brandId], references: [id])
  name                  String
  slug                  String?          @unique // human-readable enrollment URL segment (e.g. "acme-rewards-us")
  description           String?
  pointCurrencyName     String           @default("Points")
  pointToCurrencyRatio  Float            @default(0.01) // $0.01 per point
  status                ProgramStatus    @default(DRAFT)
  type                  ProgramType      @default(POINTS)
  startDate             DateTime?
  endDate               DateTime?
  budgetUsdCents        Int?
  monthlyBudgetUsdCents Int?
  budgetSpentCents      Int              @default(0)
  alertThresholdPct     Float?
  haltBehavior          HaltBehavior?
  deletedAt             DateTime? // soft delete
  earningRules          EarningRule[]
  campaigns             Campaign[]
  rewards               Reward[]
  tiers                 Tier[]
  versions              ProgramVersion[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([brandId])
  @@map("programs")
}

model EarningRule {
  id               String     @id @default(cuid())
  programId        String
  program          Program    @relation(fields: [programId], references: [id])
  brandId          String
  name             String
  triggerEvent     String // e.g. "purchase", "survey_complete", "enrollment"
  pointsAwarded    Int
  multiplier       Float      @default(1.0)
  conditions       Json? // JSONB: AND/OR condition logic
  maxUsesPerMember Int? // null = unlimited
  status           RuleStatus @default(ACTIVE)
  priority         Int        @default(0)
  stackable        Boolean    @default(false)
  budgetCapPoints  Int?
  budgetUsedPoints Int        @default(0)
  validFrom        DateTime   @default(now())
  validTo          DateTime?
  createdAt        DateTime   @default(now())

  @@index([programId, status])
  @@index([brandId])
  @@map("earning_rules")
}

model Member {
  id                   String               @id @default(cuid())
  brandId              String
  brand                Brand                @relation(fields: [brandId], references: [id])
  // Issue #231 — polymorphic identifier (PR1)
  // externalId is the canonical lookup column (lowercased + trimmed at insert/lookup).
  // PR1 ships externalId as the canonical key alongside the existing email column.
  // PR2 will make `email` nullable when auto-enrolling members for PHONE / CUSTOMER_ID brands.
  // V0 is uniformly case-insensitive across all identifier kinds (R5).
  externalId           String               // R4 — canonical lookup column (lowercased + trimmed)
  enrolledVia          MemberEnrolledVia    // R15 — set at create time per channel attribution
  // PR2 (#231): email is now nullable. Auto-enrolled members on PHONE /
  // CUSTOMER_ID brands have no email at create time; the field is populated
  // later if/when the integrator provides one (R6 idempotent upsert).
  email                String?
  clerkUserId          String?
  firstName            String?
  lastName             String?
  phone                String?
  pointsBalance        Int                  @default(0)
  status               MemberStatus         @default(ACTIVE)
  consentGivenAt       DateTime?
  consentVersion       String?
  emailOptIn           Boolean              @default(false)
  smsOptIn             Boolean              @default(false)
  deletedAt            DateTime? // soft delete (C-02)
  currentTierId        String?
  currentTier          Tier?                @relation(fields: [currentTierId], references: [id])
  erased               Boolean              @default(false) // GDPR erasure flag (C-03)
  healthScore          Int? // 0-100 computed health score (null = never computed)
  healthScoreUpdatedAt DateTime? // timestamp of last health score computation
  healthScoreBreakdown Json? // full HealthScoreBreakdown (sub-scores + note modifier + inconsistency)
  loyaltyEvents        LoyaltyEvent[]
  redemptions          Redemption[]
  campaignEvents       CampaignEvent[]
  surveyResponses      SurveyResponse[]
  conversations        Conversation[]
  notes                MemberNote[]
  externalSignals      ExternalSignal[]
  surveyDistributions  SurveyDistribution[] // Issue #117
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  // PR2 (#231): @@unique([brandId, email]) dropped — externalId is now the
  // canonical lookup. email is a PII sidecar populated when identifierKind=EMAIL
  // (and may be set via the late-arriving update path R6 for non-EMAIL brands).
  @@unique([brandId, externalId])               // R4 — canonical lookup
  @@index([brandId])
  @@index([brandId, externalId])                // R5 — canonical lookup index
  @@index([clerkUserId, brandId])
  @@index([brandId, healthScore])
  @@map("members")
}

model MemberNote {
  id        String   @id @default(cuid())
  brandId   String
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  body      String
  author    String // clerk user email, API key label, or "system"
  category  String? // optional tag: call, email, meeting, note, escalation, win-back
  sentiment String? // optional rep-tagged sentiment: very_negative, negative, neutral, positive, very_positive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId, memberId, createdAt])
  @@map("member_notes")
}

model ExternalSignalSource {
  id               String             @id @default(cuid())
  brandId          String
  brand            Brand              @relation(fields: [brandId], references: [id])
  name             String
  sourceType       ExternalSourceType
  connectionMethod String
  syncMode         ExternalSyncMode
  enabled          Boolean            @default(false)
  scopeConfig      Json
  filterConfig     Json?
  matchingConfig   Json?
  credentialRef    String?
  healthStatus     String             @default("never_synced")
  lastCursor       Json?
  lastSyncAt       DateTime?
  lastSuccessAt    DateTime?
  lastImportCount  Int?
  lastError        String?
  lastErrorAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  signals          ExternalSignal[]
  apiKeys          ApiKey[]

  @@index([brandId, enabled])
  @@index([brandId, sourceType])
  @@map("external_signal_sources")
}

model ExternalSignal {
  id                   String               @id @default(cuid())
  brandId              String
  brand                Brand                @relation(fields: [brandId], references: [id])
  sourceId             String
  source               ExternalSignalSource @relation(fields: [sourceId], references: [id])
  memberId             String?
  member               Member?              @relation(fields: [memberId], references: [id])
  sourceType           ExternalSourceType
  externalId           String
  status               ExternalSignalStatus @default(ACTIVE)
  matchStatus          ExternalMatchStatus  @default(UNMATCHED)
  matchConfidence      Float?
  matchMethod          String?
  body                 String
  summary              String?
  rating               Float?
  sentiment            Float?
  confidence           Float?
  topics               String[]
  canonicalUrl         String?
  externalAuthorHandle String?
  externalAuthorLabel  String?
  subjectType          String?
  subjectKey           String?
  subjectLabel         String?
  providerStatus       String?
  statusHistory        Json                 @default("[]")
  providerMetadata     Json?
  rawPayload           Json
  postedAt             DateTime?
  ingestedAt           DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@unique([sourceId, externalId])
  @@index([brandId, postedAt])
  @@index([brandId, matchStatus, postedAt])
  @@index([brandId, memberId, postedAt])
  @@map("external_signals")
}

model LoyaltyEvent {
  id             String   @id @default(cuid())
  brandId        String
  memberId       String
  member         Member   @relation(fields: [memberId], references: [id])
  eventType      String // "purchase", "cx.nps_submitted", "campaign_award", etc.
  pointsEarned   Int // positive = earn, negative = burn (redemption deduction)
  payload        Json? // raw event payload
  idempotencyKey String? // stored in Redis; also here for audit trail
  rulesApplied   String[] // array of EarningRule IDs applied
  campaignId     String? // if triggered by a campaign
  processedAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([brandId, createdAt]) // critical for analytics queries (R7.1, R7.5)
  @@index([brandId, eventType, createdAt]) // reach-estimate query (Issue #79)
  @@index([memberId])
  @@index([idempotencyKey])
  @@map("loyalty_events")
}

model Reward {
  id              String       @id @default(cuid())
  brandId         String
  programId       String
  program         Program      @relation(fields: [programId], references: [id])
  name            String
  description     String?
  pointsCost      Int
  stock           Int? // null = unlimited
  isAvailable     Boolean      @default(true)
  type            RewardType?
  availableFrom   DateTime?
  availableTo     DateTime?
  eligibleTierIds String[]
  deletedAt       DateTime? // soft delete
  redemptions     Redemption[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([brandId, isAvailable])
  @@map("rewards")
}

model Tier {
  id            String    @id @default(cuid())
  programId     String
  program       Program   @relation(fields: [programId], references: [id])
  brandId       String
  name          String
  rank          Int
  icon          String? // emoji preset
  minPoints     Int?
  minSpendCents Int?
  benefits      String[]
  multiplier    Float     @default(1.0)
  deletedAt     DateTime? // soft delete
  members       Member[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([programId, rank])
  @@index([brandId])
  @@map("tiers")
}

model ProgramVersion {
  id        String   @id @default(cuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id])
  brandId   String
  snapshot  Json // full program snapshot including tiers, rules, rewards
  source    String   @default("explicit_save") // "explicit_save" | "auto_save"
  createdAt DateTime @default(now())

  @@index([programId])
  @@index([brandId])
  @@map("program_versions")
}

model Redemption {
  id          String           @id @default(cuid())
  brandId     String
  memberId    String
  member      Member           @relation(fields: [memberId], references: [id])
  rewardId    String
  reward      Reward           @relation(fields: [rewardId], references: [id])
  pointsSpent Int
  status      RedemptionStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  @@index([brandId, memberId])
  @@map("redemptions")
}

model Campaign {
  id               String          @id @default(cuid())
  brandId          String
  programId        String
  program          Program         @relation(fields: [programId], references: [id])
  name             String
  triggerType      String // "cx.nps_submitted", "cx.ticket_resolved", "cx.survey_response"
  triggerCondition Json // e.g. { "field": "nps_score", "op": "lt", "value": 7 } or { surveyId, scoreMin, scoreMax }
  actionType       String // "award_points", "award_reward", "send_message"
  actionConfig     Json // e.g. { "points": 500, "message": "..." }
  budgetCap        Float? // USD value cap
  budgetSpent      Float           @default(0)
  status           CampaignStatus  @default(DRAFT)
  startDate        DateTime
  endDate          DateTime?
  surveyId         String?         // denormalized for loop monitor queries (Issue #80)
  survey           Survey?         @relation(fields: [surveyId], references: [id])
  surveyRule       SurveyRule?     // back-relation; null for non-survey campaigns
  campaignEvents   CampaignEvent[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([brandId, status])
  @@index([surveyId])
  @@map("campaigns")
}

model CampaignEvent {
  id               String         @id @default(cuid())
  brandId          String
  campaignId       String
  campaign         Campaign       @relation(fields: [campaignId], references: [id])
  memberId         String
  member           Member         @relation(fields: [memberId], references: [id])
  triggeredAt      DateTime       @default(now())
  executedAt       DateTime?
  latencyMs        Int? // measured latency from event ingestion to action execution
  status           String         @default("executed")
  result           Json? // spin_wheel: { winningIndex, rewardId?, points?, label }
  surveyResponseId String? // FK → SurveyResponse, for loop monitor linkage (Issue #80)
  surveyResponse   SurveyResponse? @relation(fields: [surveyResponseId], references: [id])

  @@unique([campaignId, memberId]) // dedup: one trigger per member per campaign (R6.4)
  @@index([brandId, campaignId])
  @@index([campaignId, surveyResponseId]) // loop monitor query performance (Issue #80)
  @@map("campaign_events")
}

model Survey {
  id                 String           @id @default(cuid())
  brandId            String
  brand              Brand            @relation(fields: [brandId], references: [id])
  programId          String
  name               String
  title              String?          // Issue #241 — respondent-facing form heading (R7 / D16); nullable; backfilled from name
  description        String?          // Issue #241 Slice 2 — list-page meta line (R26 / D26); nullable
  type               SurveyType       @default(NPS)
  questions          Json             // Question definitions (array of question objects)
  settings           Json?            // Distribution settings, branding, etc.
  status             SurveyStatus     @default(DRAFT)
  responsesCount     Int              @default(0)
  distributionCount  Int              @default(0) // incremented by survey distribution jobs (Issue #80)
  themeId            String?
  theme              BrandTheme?      @relation(fields: [themeId], references: [id])
  triggerCategory    String?          // 'loyalty' | 'cx_risk' | 'scheduled' (Issue #79)
  triggerKey         String?          // e.g. 'tier_upgrade', 'after_support' (Issue #79)
  surveyTypeOverride String?          // Manager override of recommended type (Issue #79)
  // Issue #231 — Survey response data model rework
  responsePolicy                ResponsePolicy @default(MULTIPLE)  // R3
  consentTextOverride           String?                            // R16 — null → use Brand.consentTextDefault; '' → R17 suppress UI
  consentSuppressedAttestedBy   String?                            // R17 / Issue #276 — admin/system who attested
  consentSuppressedAttestedAt   DateTime?                          // R17 / Issue #276 — attestation timestamp
  // Issue #276 — survey-level consent mode override
  consentMode                   ConsentMode?                       // null → inherit Brand.consentMode
  consentReason                 String?       @db.VarChar(500)     // operator/system justification when override is set
  // Issue #291 — per-survey thank-you copy/routing/toggle (moved from SurveyTheme)
  thankYouMessage               String        @default("Thank you for your feedback!")
  thankYouRedirectUrl           String?
  // Issue #241 — showIncentivePoints + incentivePoints removed (D19, D40, D50): points never appear
  // on the form; earning consolidates to EarningRule keyed on cx events.
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?        // Issue #332 — soft delete (matches Program/Member/Reward convention)

  responses     SurveyResponse[]
  surveyRules   SurveyRule[]         // response-to-action rules (Issue #80)
  campaigns     Campaign[]           // campaigns linked to this survey (Issue #80)
  distributions SurveyDistribution[] // triggered distribution records (Issue #117)
  importBatches SurveyImportBatch[]  // historical import batches (Issue #262)

  @@index([brandId, status])
  @@index([brandId, triggerKey, status]) // survey distribution lookup (Issue #117)
  @@map("surveys")
}

// ─── Issue #117: Survey Trigger Distribution ──────────────────────────────────

model SurveyDistribution {
  id        String   @id @default(cuid())
  surveyId  String
  survey    Survey   @relation(fields: [surveyId], references: [id])
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  brandId   String
  sentAt    DateTime @default(now())

  @@unique([surveyId, memberId]) // one active distribution record per member per survey
  @@index([surveyId, memberId, sentAt]) // cooldown window query (Issue #117)
  @@map("survey_distributions")
}

// ─── Issue #80: Response-to-Action Rule Builder ───────────────────────────────

model CxPlaybook {
  id         String     @id @default(cuid())
  brandId    String
  brand      Brand      @relation(fields: [brandId], references: [id])
  name       String
  surveyType SurveyType
  rules      Json       // Array of SurveyRuleInput objects
  deletedAt  DateTime?  // soft delete
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([brandId, name])
  @@index([brandId, surveyType])
  @@map("cx_playbooks")
}

model SurveyRule {
  id           String   @id @default(cuid())
  brandId      String
  surveyId     String
  survey       Survey   @relation(fields: [surveyId], references: [id])
  campaignId   String   @unique // one rule → one campaign (1:1)
  campaign     Campaign @relation(fields: [campaignId], references: [id])
  scoreMin     Float
  scoreMax     Float
  actionType   String   // award_points | award_reward | send_message | spin_wheel | scratch_card | mystery_box
  actionConfig Json     // same shape as Campaign.actionConfig
  ruleLabel    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([surveyId])
  @@index([brandId])
  @@map("survey_rules")
}

// Issue #291 — Renamed from SurveyTheme; brand-level visual identity only.
// Per-survey overrides (thank-you copy, redirect URL, incentive-points toggle)
// moved to Survey columns. Logo / brand-name fall through to Brand.logoUrl /
// Brand.name. Default-theme flag replaced by Brand.defaultThemeId FK.
model BrandTheme {
  id        String  @id @default(cuid())
  brandId   String
  brand     Brand   @relation("BrandThemes", fields: [brandId], references: [id])
  name      String

  primaryColor    String @default("#6366f1")
  secondaryColor  String @default("#818cf8")
  backgroundColor String @default("#ffffff")
  textColor       String @default("#111827")
  buttonColor     String @default("#6366f1")
  buttonTextColor String @default("#ffffff")
  accentColor     String @default("#6366f1")

  fontFamily  String @default("system-ui")
  headingSize String @default("md")
  bodySize    String @default("md")

  backgroundImageUrl String?
  cardStyle          String  @default("shadow")
  borderRadius       String  @default("md")
  maxWidth           String  @default("md")

  surveys          Survey[]
  defaultForBrands Brand[]  @relation("BrandDefaultTheme")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@map("brand_themes")
}

model QuestionTemplate {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id])
  name      String
  question  Json // Full SurveyQuestion object
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@map("question_templates")
}

model SurveyResponse {
  id             String           @id @default(cuid())
  surveyId       String
  survey         Survey           @relation(fields: [surveyId], references: [id])
  memberId       String?          // null for anonymous sources (e.g. Google Reviews)
  member         Member?          @relation(fields: [memberId], references: [id])
  brandId        String
  answers        Json             // { questionId: answer }
  score          Float?           // NPS (0-10), CSAT (1-5), CES (1-7) numeric score
  sentiment      Float?           // -1.0 to 1.0 (AI-analyzed from open-ended text)
  confidence     Float?           // AI confidence in sentiment score, 0.0 to 1.0
  topics         String[]         // AI-extracted topics from open-ended responses
  summary        String?          // AI-generated one-line summary
  clusterId      String?          // FK to FeedbackCluster
  cluster        FeedbackCluster? @relation(fields: [clusterId], references: [id])
  channel        String           @default("link") // email, in_app, link, sms, review
  completedAt    DateTime         @default(now())
  createdAt      DateTime         @default(now())
  campaignEvents CampaignEvent[]  // campaign events triggered by this response (Issue #80)
  caseFollowUps  CaseFollowUp[]   // cases opened from this response

  // Issue #262: historical import fields (null = live response)
  importBatchId        String?
  importBatch          SurveyImportBatch? @relation(fields: [importBatchId], references: [id])
  importedAt           DateTime?          // original response timestamp from source
  externalRespondentId String?            // source-system respondent ID for deduplication

  // R2 — `@@unique([surveyId, memberId])` removed; policy-controlled by Survey.responsePolicy (R3).
  // #262 — partial unique index for live-response dedup lives in migration, not schema.
  @@index([surveyId, memberId]) // R3 enforcement lookups + import history
  @@index([brandId, completedAt])
  @@index([clusterId])
  @@index([importBatchId])
  @@map("survey_responses")
}

// Issue #262: tracks a single historical import operation
model SurveyImportBatch {
  id            String           @id @default(cuid())
  surveyId      String
  survey        Survey           @relation(fields: [surveyId], references: [id])
  brandId       String
  sourceType    String           // 'excel' | 'google_reviews'
  filename      String?
  status        String           @default("pending") // pending | processing | complete | failed
  totalRows     Int              @default(0)
  processedRows Int              @default(0)
  failedRows    Int              @default(0)
  errors        Json             @default("[]") // array of { rowIndex, message }
  deletedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  responses SurveyResponse[]

  @@index([surveyId])
  @@index([brandId, createdAt])
  @@map("survey_import_batches")
}

model FeedbackCluster {
  id            String   @id @default(cuid())
  brandId       String
  label         String
  description   String?
  keywords      String[]
  avgSentiment  Float?
  responseCount Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  responses SurveyResponse[]
  snapshots ClusterSnapshot[]

  @@unique([brandId, label])
  @@index([brandId, isActive])
  @@map("feedback_clusters")
}

model ClusterSnapshot {
  id           String          @id @default(cuid())
  clusterId    String
  cluster      FeedbackCluster @relation(fields: [clusterId], references: [id])
  brandId      String
  bucketDate   DateTime // Start of the day bucket
  volume       Int // Number of responses in this bucket
  avgSentiment Float?
  isAnomaly    Boolean         @default(false)
  zScore       Float?
  createdAt    DateTime        @default(now())

  @@unique([clusterId, bucketDate])
  @@index([brandId, bucketDate])
  @@map("cluster_snapshots")
}

model FeedbackAnomaly {
  id         String    @id @default(cuid())
  brandId    String
  clusterId  String?
  type       String // volume_spike, sentiment_drop, new_theme, volume_decline
  severity   String // low, medium, high
  summary    String
  detectedAt DateTime  @default(now())
  resolvedAt DateTime?
  metadata   Json?

  @@index([brandId, detectedAt])
  @@map("feedback_anomalies")
}

model AlertRule {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])
  name    String
  status  String @default("ACTIVE") // ACTIVE, PAUSED

  // Trigger conditions
  surveyTypes        String[] // ['NPS', 'CSAT'] or empty = all
  scoreMin           Float?
  scoreMax           Float?
  sentimentThreshold Float? // alert if sentiment below this
  topicFilters       String[] // ['shipping', 'billing'] or empty = all

  // Alert channels
  slackWebhookUrl  String?
  slackChannelName String?
  emailRecipients  String[]
  teamsWebhookUrl  String?

  // Assignment
  defaultAssignee String
  assignmentRules Json   @default("[]") // [{ topic, assignee }]

  // SLA
  slaHours Float?

  cases CaseFollowUp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId, status])
  @@map("alert_rules")
}

model CaseFollowUp {
  id               String    @id @default(cuid())
  brandId          String
  brand            Brand     @relation(fields: [brandId], references: [id])
  alertRuleId      String
  alertRule        AlertRule      @relation(fields: [alertRuleId], references: [id])
  surveyResponseId String?        // nullable: cases can be created without a survey response
  surveyResponse   SurveyResponse? @relation(fields: [surveyResponseId], references: [id])
  memberId         String

  status   String @default("OPEN") // OPEN, CONTACTED, RESOLVED, CLOSED
  assignee String
  priority String @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL

  // SLA
  slaDeadline   DateTime?
  slaBreachedAt DateTime?

  // External references
  slackMessageTs String?

  // Notes / timeline
  notes Json @default("[]") // [{ text, author, timestamp, statusChange? }]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contactedAt DateTime?
  resolvedAt  DateTime?
  closedAt    DateTime?

  @@index([brandId, status])
  @@index([alertRuleId])
  @@map("case_follow_ups")
}

model DemoRequest {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  workEmail   String
  companyName String
  companySize String?
  message     String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("demo_requests")
}

model AuditEvent {
  id           String   @id @default(cuid())
  brandId      String? // null for system-level events
  actorId      String // Clerk user ID
  action       String // "program.create", "campaign.activate", etc.
  resourceType String
  resourceId   String
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([brandId, createdAt])
  @@map("audit_events")
}

// ─── Support Chat Models ─────────────────────────────────────────────────────

model Conversation {
  id       String @id @default(cuid())
  brandId  String
  brand    Brand  @relation(fields: [brandId], references: [id])
  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  status     ConversationStatus @default(ACTIVE)
  intent     String? // classified intent (billing, shipping, etc.)
  confidence Float? // intent classification confidence
  topic      String? // extracted topic
  summary    String? // AI-generated conversation summary

  // Escalation
  assignee       String? // human agent email
  caseFollowUpId String? // FK to CaseFollowUp if escalated
  escalatedAt    DateTime?

  // Rules matched
  rulesMatched String[] // SupportRule IDs that fired

  messages Message[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
  closedAt   DateTime?

  @@index([brandId, status])
  @@index([memberId])
  @@index([brandId, createdAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  role     MessageRole // CUSTOMER, AI, AGENT
  content  String // message text
  metadata Json? // { kbArticleIds, customer360Snapshot, intentResult, confidence }

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

model SupportRule {
  id          String  @id @default(cuid())
  brandId     String
  brand       Brand   @relation(fields: [brandId], references: [id])
  name        String
  description String?
  status      String  @default("ACTIVE") // ACTIVE, PAUSED
  priority    Int     @default(0) // lower = evaluated first

  // Match conditions
  intentFilters  String[] // ["billing", "shipping"] or empty = all
  tierFilters    String[] // ["Gold", "Platinum"] or empty = all
  healthScoreMin Float? // match if health score >= this
  healthScoreMax Float? // match if health score <= this
  topicFilters   String[] // ["refund", "overcharge"] or empty = all
  conditions     Json     @default("{}") // ConditionGroup for additional field/op/value matching

  // Actions (multiple can fire)
  autoRespondArticleId String? // KB article ID to auto-respond with
  escalateToAssignee   String? // human agent email for escalation
  awardPoints          Int? // compensatory points to award
  triggerSurveyId      String? // post-resolution survey to trigger

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId, status])
  @@map("support_rules")
}

model KBArticle {
  id        String                       @id @default(cuid())
  brandId   String
  title     String
  body      String // Markdown content
  category  KBArticleCategory            @default(FAQ)
  tags      String[]
  status    KBArticleStatus              @default(DRAFT)
  embedding Unsupported("public.vector(1536)")? // pgvector -- schema-qualified so db push works in isolated test schemas
  deletedAt DateTime? // soft delete (GDPR/CCPA, project rule #13)
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt

  @@index([brandId, status])
  @@index([brandId, category])
  @@map("kb_articles")
}

// ─── MCP OAuth ────────────────────────────────────────────────────────────────

// Short-lived authorization code issued during the MCP OAuth flow.
// Exchanged (once) for a bearer token in POST /mcp/token.
model McpOAuthCode {
  id                  String    @id @default(cuid())
  code                String    @unique
  brandId             String
  clerkUserId         String
  clientId            String
  redirectUri         String
  codeChallenge       String    // PKCE S256 challenge (base64url SHA-256 of verifier)
  codeChallengeMethod String    @default("S256")
  expiresAt           DateTime
  usedAt              DateTime? // set when exchanged — prevents replay
  createdAt           DateTime  @default(now())

  @@index([code])
  @@map("mcp_oauth_codes")
}

// ─── Outbound Webhooks ────────────────────────────────────────────────────────

model WebhookEndpoint {
  id            String               @id @default(cuid())
  brandId       String
  brand         Brand                @relation(fields: [brandId], references: [id])
  label         String
  // NOTE: url and signingSecret are stored plaintext. Encrypt at rest before
  // enabling in production — hard dependency on issue #53.
  url           String
  signingSecret String
  events        String[]
  active        Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deliveries    WebhookDeliveryLog[]

  @@index([brandId, active])
  @@map("webhook_endpoints")
}

model WebhookDeliveryLog {
  id                String          @id @default(cuid())
  webhookEndpointId String
  endpoint          WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  brandId           String
  event             String
  caseId            String
  httpStatus        Int?
  latencyMs         Int?
  success           Boolean
  attempt           Int             @default(1)
  requestPayload    Json
  responseBody      String?
  deliveredAt       DateTime        @default(now())

  @@index([webhookEndpointId, deliveredAt(sort: Desc)])
  @@index([brandId, deliveredAt(sort: Desc)])
  @@map("webhook_delivery_logs")
}

// ─── Onboarding (Issue #170) ──────────────────────────────────────────────────

// 1:1 with Brand. Stores per-brand onboarding progress (which milestones have
// fired, which use-case path the admin picked, which admins have dismissed
// the post-activation widget). Single mutable row per brand; activation
// history lives in OnboardingActivationEvent.
model OnboardingState {
  id                  String       @id @default(cuid())
  brandId             String       @unique
  brand               Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)

  useCasePath         UseCasePath?
  // Shape: { brandCreated, dataSourceConnected, firstEventReceived,
  //          firstSurveyLive, firstActionTriggered, programCreated }
  // The patch handler enforces the precondition: firstActionTriggered=true
  // requires programCreated=true (per spec).
  checklist           Json         @default("{}")
  dismissedByUserIds  String[]     @default([])
  invitedAdminUserIds String[]     @default([])

  activatedAt         DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([activatedAt])
  @@map("onboarding_state")
}

// Append-only funnel events. Never UPDATE or DELETE outside the GDPR erasure
// path. dwellMs is the gap from previousStep.occurredAt; null on the first
// event. metadata captures per-step context (oauth provider, picked path,
// etc.) for forensics.
model OnboardingActivationEvent {
  id           String          @id @default(cuid())
  brandId      String
  brand        Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)

  step         OnboardingStep
  previousStep OnboardingStep?
  occurredAt   DateTime        @default(now())
  dwellMs     Int?
  metadata     Json            @default("{}")

  @@index([brandId, occurredAt])
  @@index([step, occurredAt])
  @@map("onboarding_activation_events")
}

