{
  "name": "@customerEQ/ai",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm run generate && tsc",
    "typecheck": "pnpm run generate && tsc --noEmit",
    "test": "pnpm run generate && vitest run --reporter=verbose",
    "test:smoke": "pnpm run generate && vitest run --reporter=verbose",
    "test:baml": "pnpm run generate && vitest run --config vitest.eval.config.ts --reporter=verbose",
    "generate": "npx @boundaryml/baml@0.211.0 generate"
  },
  "dependencies": {
    "@boundaryml/baml": "0.211.0",
    "@customerEQ/database": "workspace:*",
    "@customerEQ/shared": "workspace:*",
    "dotenv": "^17.3.1",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
