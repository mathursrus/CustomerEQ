  },
  "repository": {
    "provider": "github",
    "owner": "mathursrus",
    "name": "CustomerEQ",
    "url": "https://github.com/mathursrus/CustomerEQ/",
    "defaultBranch": "main"
  },
  "issueTracking": {
    "provider": "github",
    "owner": "mathursrus",
