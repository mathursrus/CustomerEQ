    "localDev": {
      "setupCommand": "docker compose up -d && pnpm install && pnpm db:migrate && pnpm db:seed",
      "devCommand": "pnpm dev",
      "notes": "Requires Docker (PostgreSQL + Redis), Node.js 20+, pnpm 9. Host-installed Postgres on :5432 must be stopped — see project rule R19."
    },
    "validation": {
      "buildCommand": "pnpm build",
      "testSuiteCommand": "pnpm test",
      "smokeTestCommand": "pnpm test:smoke",
      "build": "pnpm build",
      "test": "pnpm test",
      "typecheck": "pnpm typecheck",
      "lint": "pnpm lint",
      "smoke": "pnpm build && pnpm typecheck && pnpm test",
      "e2e": "pnpm test:e2e"
    },
    "compliance": {
      "regulations": [
        "GDPR",
        "CCPA",
        "SOC2",
        "PCI-DSS"
      ],
      "compliance_specifications": {
        "GDPR": "in-scope",
        "CCPA": "in-scope",
        "SOC2": "target: month-12",
        "PCI-DSS": "minimal-scope"
