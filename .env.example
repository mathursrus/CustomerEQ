# Database
DATABASE_URL="postgresql://customerEQ:customerEQ@localhost:5432/customerEQ"

# Queue mode
# `redis` (default) â€” async via BullMQ + Redis. Optimized for throughput,
# cross-instance dedup, and BullMQ retry/backoff.
# `inline` â€” same workflows run synchronously in-process against Postgres.
# No Redis required. Functionally equivalent to redis mode; only differs
# in when/how fast work happens.
QUEUE_MODE="redis"

# Redis (only required when QUEUE_MODE=redis)
REDIS_URL="redis://localhost:6379"

# Clerk Authentication
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Webhook Secrets (set per integration in production)
CEQ_SALESFORCE_WEBHOOK_SECRET="your-salesforce-hmac-secret"
CEQ_HUBSPOT_WEBHOOK_SECRET="your-hubspot-hmac-secret"

# Observability
AZURE_APPLICATION_INSIGHTS_CONNECTION_STRING="InstrumentationKey=..."

# Azure OpenAI (required for BAML evals and live BAML-backed analysis paths)
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_BASE_URL="https://your-resource.openai.azure.com/openai/v1"

# API
API_PORT=4000
API_HOST=0.0.0.0
# Support contact surfaced in the admin Organization Settings page (Issue #277).
# Falls back to "support@customereq.com" if unset.
SUPPORT_EMAIL=support@customereq.com

# Email (stub for MVP â€” ACS custom-domain delivery supported in production)
EMAIL_PROVIDER="stub"
# EMAIL_PROVIDER="azure-communication-services"
# AZURE_COMMUNICATION_SERVICES_CONNECTION_STRING="endpoint=https://<resource>.communication.azure.com/;accesskey=<key>"
# AZURE_COMMUNICATION_SERVICES_EMAIL_FROM="no-reply@customereq.wellnessatwork.me"
# SENDGRID_API_KEY="SG...."
# RESEND_API_KEY="re_..."

# Social Integration Credentials (platform-level â€” shared across all org sources)
CEQ_REDDIT_CLIENT_ID=""
CEQ_REDDIT_CLIENT_SECRET=""
CEQ_X_BEARER_TOKEN=""
CEQ_GOOGLE_CLIENT_ID=""
CEQ_GOOGLE_CLIENT_SECRET=""
CEQ_LINKEDIN_CLIENT_ID=""
CEQ_LINKEDIN_CLIENT_SECRET=""

# OAuth Configuration
CEQ_OAUTH_STATE_SECRET="change-me-to-a-random-32-byte-hex-string"
CEQ_OAUTH_CALLBACK_BASE_URL="http://localhost:4000"
CEQ_ADMIN_UI_BASE_URL="http://localhost:3000"
