# Enforce LF line endings on commit for all text files regardless of
# contributor OS. Stops Windows checkouts from producing CRLF-vs-LF noise
# on every diff. core.autocrlf=false alone does not protect against editors
# that save CRLF; these per-extension rules do.

* text=auto eol=lf

# ─── Source code ─────────────────────────────────────────────────────────
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf

# ─── Config & data ───────────────────────────────────────────────────────
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.csv       text eol=lf

# ─── Docs ────────────────────────────────────────────────────────────────
*.md        text eol=lf
*.mdc       text eol=lf
*.txt       text eol=lf

# ─── Database ────────────────────────────────────────────────────────────
*.prisma    text eol=lf
*.sql       text eol=lf

# ─── Frontend assets (text) ──────────────────────────────────────────────
*.css       text eol=lf
*.html      text eol=lf
*.svg       text eol=lf

# ─── Shell / scripts ─────────────────────────────────────────────────────
*.sh        text eol=lf

# ─── Other text formats ──────────────────────────────────────────────────
*.baml      text eol=lf

# ─── Dotfiles & extensionless files ──────────────────────────────────────
.gitignore        text eol=lf
.gitattributes    text eol=lf
.dockerignore     text eol=lf
.nvmrc            text eol=lf
.env*             text eol=lf
Dockerfile        text eol=lf
Dockerfile.*      text eol=lf

# ─── Binary (explicit — never touched) ───────────────────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.zip       binary
*.tar       binary
*.tgz       binary
*.gz        binary
