# CustomerEQ API base URL
# Local: http://localhost:4000
# Prod:  https://customereq-api.salmonsea-4eb14bdc.eastus.azurecontainerapps.io
CUSTOMEREQ_API_URL="http://localhost:4000"

# Server-to-server API key (X-Api-Key header)
# This is the credential a real customer product would use to integrate with
# CustomerEQ. Get one from your CustomerEQ admin → Settings → API Keys.
CUSTOMEREQ_API_KEY=""

# Brand ID for the API key (X-Api-Key requires CUSTOMEREQ_BRAND_ID alongside).
# In real integrations the API key encodes this; for demo we pass it explicitly.
CUSTOMEREQ_BRAND_ID=""

# Loyalty program slug — used by member enrollment and redemption flows.
# Defaults to the seeded demo program.
CUSTOMEREQ_PROGRAM_SLUG="diamond-loyalty-club"

# Public survey IDs to embed on the demo product pages
CUSTOMEREQ_NPS_SURVEY_ID=""
CUSTOMEREQ_CSAT_SURVEY_ID=""

# External signal source ID + shared secret for the Google/social reviews
# webhook forwarding. Provision these in CustomerEQ admin → Integrations.
CUSTOMEREQ_REVIEW_SOURCE_ID=""
CUSTOMEREQ_REVIEW_SOURCE_SECRET=""

# Demo server port
PORT=5000
