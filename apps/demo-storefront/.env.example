# Demo storefront configuration
# Copy to .env.local and adjust as needed.

# CustomerEQ API URL (server-side only — not exposed to browser)
DEMO_API_URL=http://localhost:4000

# Brand ID for demo tenant (must match the brand created by setup:dev-brand or seed:demo)
DEMO_BRAND_ID=cmn689ibu000089tqad1g234t

# Public brand config — exposed to the browser (NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_DEMO_BRAND_NAME=StarBrew Coffee
NEXT_PUBLIC_DEMO_BRAND_PRIMARY_COLOR=#00704A
NEXT_PUBLIC_DEMO_BRAND_SECONDARY_COLOR=#CBA258
NEXT_PUBLIC_DEMO_BRAND_LOGO=
NEXT_PUBLIC_DEMO_API_URL=http://localhost:4000
