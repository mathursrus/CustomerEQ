{
  "cli": {
    "version": ">= 19.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "config": "eas-build-ios-preview.yml",
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "NPM_CONFIG_IGNORE_SCRIPTS": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
