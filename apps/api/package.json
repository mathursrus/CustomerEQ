{
  "name": "@customerEQ/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/app.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "dotenv -e .env -- tsx watch src/server.ts",
    "dev:inline": "dotenv -e .env -- tsx watch src/server-inline.ts",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "test": "vitest run --reporter=verbose",
    "test:smoke": "vitest run --reporter=verbose",
    "test:integration": "vitest run --config vitest.integration.config.ts --reporter=verbose",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.14",
    "@clerk/fastify": "^3.1.16",
    "@customerEQ/ai": "workspace:*",
    "@customerEQ/connectors": "workspace:*",
    "@customerEQ/consent-text": "workspace:*",
    "@customerEQ/database": "workspace:*",
    "@customerEQ/shared": "workspace:*",
    "@customerEQ/worker": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "@prisma/client": "^5.13.0",
    "bullmq": "^5.7.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^4.5.0",
    "ioredis": "^5.3.0",
    "pino": "^9.1.0",
    "svix": "^1.31.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@customerEQ/config": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "dotenv-cli": "^11.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.9.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
